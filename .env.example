# Frontend
VITE_API_BASE_URL=http://localhost:8080/api

# Backend
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# AI provider
# mock is the default and should require no external credentials.
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=
AI_ENDPOINT=
AWS_REGION=us-east-1

# Database
DATABASE_URL=
DATABASE_USERNAME=
DATABASE_PASSWORD=

# Upload limits
MAX_FILE_SIZE_MB=2
MAX_SCAN_FILES=50

# Storage
STORE_RAW_FILES=false