VITE_API_BASE_URL=http://localhost:8080/api
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
AI_PROVIDER=mock
# AI_PROVIDER=mock is the default and needs no AWS credentials. Set AI_PROVIDER=bedrock only after configuring AWS credentials and model access.
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_MAX_TOKENS=1200
BEDROCK_TEMPERATURE=0.2
BEDROCK_SEND_RAW_CONTENT=false
BEDROCK_TIMEOUT_SECONDS=30
DATABASE_URL=
DATABASE_USERNAME=
DATABASE_PASSWORD=
MAX_FILE_SIZE_MB=2
MAX_SCAN_FILES=50
STORE_RAW_FILES=false
